# Copy this file's variable names into your Vercel Project Settings -> Environment Variables.
# Never commit real secret values to the repository.

# A GitHub Personal Access Token with permission to read/write contents
# of GITHUB_OWNER/GITHUB_REPO. See SETUP.md for how to create one safely.
GITHUB_TOKEN=

# The GitHub username or organization that owns the repo, e.g. "VishnuRali"
GITHUB_OWNER=

# The repository name only (not the full URL), e.g. "portfolio"
GITHUB_REPO=

# Optional: branch to commit to. Defaults to "main" if not set.
GITHUB_BRANCH=main

# The password you will type at vishnuvardhanrali.com/admin to log in.
# Choose something long and unique - this is the only thing protecting
# write access to your site's content.
ADMIN_PASSWORD=
